# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your account password)
# Enable 2FA, then: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
# Accepts a comma-separated list of addresses (e.g. you@gmail.com, friend@gmail.com)
ALERT_EMAIL_TO=you@gmail.com,friend@gmail.com

# ── Gemini API (LLM classification) ──────────────────────────────────────────
# Free tier: https://aistudio.google.com/app/apikey
# Free quota: ~1,500 requests/day (more than enough for yes/no job classification)
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Pipeline behaviour ────────────────────────────────────────────────────────
# How often the scheduler runs (in hours). Default: 6
RUN_INTERVAL_HOURS=6

# Delay between HTTP requests (be polite to career pages). Default: 1.0 seconds
REQUEST_DELAY=1.0

# Set to false to scrape + filter without sending any notifications (useful for testing)
NOTIFY_ENABLED=true

# Set to true to run the full pipeline without writing to DB or notifying
DRY_RUN=false

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Optional: override the DB path (default: database/jobs.db)
# DB_PATH=/path/to/your/jobs.db
